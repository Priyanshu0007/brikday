{
  "name": "brikday",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "dependencies": {
    "@expo-google-fonts/plus-jakarta-sans": "~0.4.2",
    "@expo-google-fonts/space-grotesk": "~0.4.1",
    "@expo-google-fonts/space-mono": "~0.4.2",
    "@legendapp/list": "3.0.0",
    "@legendapp/state": "^3.0.0-beta.47",
    "@lodev09/react-native-true-sheet": "^3.10.1",
    "expo": "~56.0.8",
    "expo-constants": "~56.0.16",
    "expo-dev-client": "~56.0.18",
    "expo-device": "~56.0.4",
    "expo-font": "~56.0.5",
    "expo-glass-effect": "~56.0.4",
    "expo-image": "~56.0.9",
    "expo-linking": "~56.0.13",
    "expo-notifications": "~56.0.18",
    "expo-router": "~56.2.8",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.5",
    "expo-system-ui": "~56.0.5",
    "expo-web-browser": "~56.0.5",
    "pressto": "^0.6.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-mmkv": "4.3.1",
    "react-native-nitro-modules": "0.35.9",
    "react-native-pager-view": "8.0.1",
    "react-native-pulsar": "^1.6.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-unistyles": "3.2.5",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "eslint": "9.39.4",
    "eslint-config-expo": "~56.0.4",
    "prettier": "3.9.1",
    "react-native-performance": "6.0.0",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "prebuild": "expo prebuild",
    "prebuild:clean": "expo prebuild --clean",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "clean": "bun run clean:build && bun run clean:cache",
    "clean:build": "rm -rf android/build android/app/build ios/build ios/DerivedData dist",
    "clean:cache": "watchman watch-del-all && rm -rf .expo node_modules/.cache",
    "clean:native": "rm -rf android ios",
    "build:android-apk": "bun run prebuild && cd android && ./gradlew assembleRelease",
    "build:android-bundle": "bun run prebuild && cd android && ./gradlew bundleRelease",
    "build:ios-release": "bun run prebuild && bun expo run:ios --configuration Release",
    "build:js-bundle": "bun run prebuild && bun expo export"
  },
  "private": true
}
