    "expo": "57.0.1",
    "expo-build-properties": "~57.0.2",
    "expo-constants": "~57.0.2",
    "expo-dev-client": "~57.0.4",
    "expo-device": "~57.0.0",
    "expo-font": "~57.0.0",
    "expo-glass-effect": "~57.0.0",
    "expo-image": "~57.0.0",
    "expo-linking": "~57.0.1",
    "expo-notifications": "~57.0.2",
    "expo-router": "~57.0.2",
    "expo-sharing": "~57.0.1",
    "expo-splash-screen": "~57.0.1",
    "expo-status-bar": "~57.0.0",
    "expo-symbols": "~57.0.0",
    "expo-system-ui": "~57.0.0",
    "expo-web-browser": "~57.0.0",
    "pressto": "0.6.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-mmkv": "4.3.1",
    "react-native-nitro-modules": "0.35.9",
    "react-native-pager-view": "8.0.2",
    "react-native-pulsar": "1.6.1",
    "react-native-reanimated": "4.5.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-unistyles": "3.2.5",
    "react-native-view-shot": "5.1.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.10.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/react": "~19.2.2",
    "babel-plugin-transform-remove-console": "^6.9.4",
    "eslint": "9.39.4",
    "eslint-config-expo": "~57.0.0",
    "jest": "^30.4.2",
    "prettier": "3.9.1",
    "react-native-performance": "6.0.0",
    "ts-jest": "^29.4.11",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "test": "jest",
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "prebuild": "expo prebuild",
    "prebuild:clean": "expo prebuild --clean",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "clean": "bun run clean:build && bun run clean:cache",
    "clean:build": "rm -rf android/build android/app/build ios/build ios/DerivedData dist",
    "clean:cache": "watchman watch-del-all && rm -rf .expo node_modules/.cache",
    "clean:native": "rm -rf android ios",
    "build:android-apk": "bun run prebuild && cd android && ./gradlew assembleRelease",
    "build:android-bundle": "bun run prebuild && cd android && ./gradlew bundleRelease",
    "build:ios-release": "bun run prebuild && bun expo run:ios --configuration Release",
    "build:js-bundle": "bun run prebuild && bun expo export",
    "postinstall": "node ./scripts/patch-reanimated.js"
  },
  "private": true
}